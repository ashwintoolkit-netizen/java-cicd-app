pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                dir('java-cicd-app') {
                    sh 'mvn clean package'
                }
            }
        }

        stage('Copy to Ansible Server') {
            steps {
                sh 'scp java-cicd-app/target/app.jar ashu@192.168.47.132:/home/ashu/app.jar'
            }
        }

        stage('Deploy via Ansible') {
            steps {
                sh 'ssh ashu@192.168.47.132 "ansible-playbook -i /home/ashu/hosts /home/ashu/deploy.yml"'
            }
        }
    }
}
